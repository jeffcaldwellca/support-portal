---
/* Ticket-stub perforation — the signature divider. Echoes the logo's ticket
   shape between major sections. Decorative only. */
---
<div class="mx-auto max-w-6xl px-4" aria-hidden="true">
  <div class="relative border-t border-dashed border-slate-300 dark:border-slate-700">
    <span class="absolute -left-2.5 -top-[11px] h-5 w-5 rounded-full border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-950"></span>
    <span class="absolute -right-2.5 -top-[11px] h-5 w-5 rounded-full border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-950"></span>
  </div>
</div>
